{
  "name": "kyleboss.com",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@types/react": "^16.0.31",
    "@types/react-dom": "^16.0.3",
    "node-sass-chokidar": "0.0.3",
    "react": "^16.2.0",
    "react-dom": "^16.2.0",
    "react-heap": "^0.1.3",
    "react-scripts": "1.0.17",
    "typescript": "^2.6.2"
  },
  "scripts": {
    "start-js": "react-scripts start",
    "start": "$(npm bin)/npm-run-all -p watch-css start-js",
    "build-js": "react-scripts build",
    "build": "$(npm bin)/npm-run-all build-css build-js",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "build-css": "./node_modules/.bin/node-sass-chokidar --include-path ./node_modules src/ -o src/",
    "watch-css": "npm run build-css node-sass-chokidar --include-path ./src --include-path ./node_modules src/ -o src/ --watch --recursive"
  },
  "devDependencies": {
    "css-loader": "^0.28.7",
    "node-sass": "^4.7.2",
    "npm-run-all": "^4.1.2",
    "sass-loader": "^6.0.6",
    "style-loader": "^0.19.1",
    "webpack": "^3.10.0",
    "webpack-dev-server": "^2.9.7"
  },
  "description": "This project holds the code for my resume/portfolio. You can find it at http://kyleboss.com",
